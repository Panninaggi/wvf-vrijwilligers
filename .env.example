# Kopieer dit bestand naar .env en vul de waarden in
# Het .env bestand wordt NIET naar GitHub gepusht (staat in .gitignore)

# Verplicht: willekeurige lange string, bijv. gegenereerd via:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=vervang-dit-door-een-lange-willekeurige-string

# Database locatie (op Railway: /data/vrijwilligers.db)
DB_PATH=/data/vrijwilligers.db

# Productie-modus (zet op 'production' bij live gebruik)
FLASK_ENV=production

# App URL (voor links in e-mails)
APP_URL=https://jouw-app.railway.app

# E-mail instellingen (optioneel — voor notificaties naar profieleigenaren)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jouw@gmail.com
SMTP_PASS=jouw-app-wachtwoord
SMTP_FROM=WVF Vrijwilligers <noreply@wvf.nl>
